# ─────────────────────────────────────────────────────────────────────────────
# AuraLearn — Environment Variables
# Copy this file to .env and fill in the values.
# .env is gitignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────────────────────
# Random 32-char string used to sign JWT tokens.
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me-in-production-32-chars!!

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Replit provisions this automatically).
DATABASE_URL=postgresql://user:password@localhost:5432/academic_assistant

# ── Mistral AI ────────────────────────────────────────────────────────────────
# Required for: summaries, RAG chat, quiz generation, flashcards, concept extraction.
# Get your key at: https://console.mistral.ai
MISTRAL_API_KEY=zyKOnVT7YmC68foTJV9ejlqT7ySCV3iM

# Which Mistral model to use (mistral-large-latest is the default).
# Other options: mistral-small-latest, open-mistral-7b
MISTRAL_MODEL=mistral-large-latest

# ── Embeddings ────────────────────────────────────────────────────────────────
# Sentence-transformer model for document embeddings (runs locally, no key needed).
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# ── ChromaDB (vector store) ───────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=academic_documents

# ── File Uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=100

# ── Text Chunking ─────────────────────────────────────────────────────────────
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ── RAG Retrieval ─────────────────────────────────────────────────────────────
# How many chunks to retrieve from ChromaDB per question.
RETRIEVAL_K=5
